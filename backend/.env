# AeroNetB API – Environment Variables
# Copy this file to .env and fill in your values before starting the server.

# ── PostgreSQL ──────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=aeronetb
PG_USER=aeronetb_user
PG_PASSWORD=aeronetb_pass

# ── MongoDB ─────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=aeronetb_docs

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=aeronetb_dev_secret
JWT_EXPIRES_IN=8h

# ── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
